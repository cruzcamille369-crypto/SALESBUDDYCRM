# Secure Connection Variables
# Ensure this file is never committed to version control.
# Copy to .env for local development

# ----------------------------------------
# 1. Third-party APIs & Secrets
# ----------------------------------------
# Gemini API Key (Server-side Only)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key for Address Validation and Mapping
# Note: Prefix with VITE_ to expose this to the frontend components!
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Twilio Access Keys for Phone Lookup
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here

# Outbound Dialer Webhook Secret
DIALER_WEBHOOK_SECRET=your_secret_here

# Session / JWT Secret for Authentication Verification
JWT_SECRET=super_secret_jwt_signature_key
